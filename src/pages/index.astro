---
import Layout from "@layouts/Layout.astro";
import PageHeader from "@components/Astro/PageHeader.astro";
import Card from "@components/Astro/Card.astro";
import coverImage from "@assets/alk-cover-2.webp";
import Link from "@components/Astro/Link.astro";

import { Image } from "astro:assets";
import Bing from "@assets/bing.jpg";

const description =
	"Build modern websites in minutes with Alkaline - a near-zero-dependency, framework-less, type-safe Astro starter kit. Featuring 14 unique color themes and more than 2 dozen pre-built Astro components, Alkaline is perfect for blogs, portfolios, e-commerce sites, and more.";
---

<Layout>
	<PageHeader
		heading="Transform The Web With Alkaline"
		description={description}
		image={coverImage}
		imageAlt="Alkaline theme preview showcasing clean and modern design"
		backgroundPattern="M20.3 29.35l-3.1-3.2-3.55 3.55-3.55-3.55 3.55-3.55 3.55 3.55L31.35 12 27.8 8.45l-3.55 3.55 3.55 3.55L30.9 18.65l-3.35 3.6L20.75 15.55l3.55-3.55L17.2 4.95 20.7 1.3l3.55 3.6L20.75 8.45 17.2 12l-7.45-7.45L13.35.9l3.85 4.05-3.55 3.55-3.55 3.55 3.55 3.55-3.55 3.55-3.55-3.55-3.9-3.9 3.55-3.55L13.65 15.55l-3.55-3.55L3.05 19.1l3.55 3.55L13.65 15.55l-3.55 3.55 3.55 3.55 3.55-3.55L23.75 25.8l.05.05-3.5 3.5"
		patternOpacity={0.25}
		animate={true}
	/>
	<section
		class="flex flex-wrap flex-row justify-center gap-12 mx-0 mt-32 lg:mt-6 lg:justify-around build-in"
	>
		<Card
			title="Configure"
			description="Single config file, TypeScript support, and pre-built components for rapid development."
			shadowSize="lg"
			name="ri:settings-3-line"
		/>
		<Card
			title="Connect"
			description="Built on pure Astro - add frameworks only when you need them. Ship less JavaScript by default."
			shadowSize="lg"
			name="ri:puzzle-2-line"
		/>
		<Card
			title="Customize"
			description="14 unique themes with consistent design patterns and extensive customization options."
			shadowSize="lg"
			name="ri:cake-3-line"
		/>
	</section>

	<section
		class="flex flex-col items-center justify-center mt-12 mb-44 build-in"
	>
		<h2
			class="bg-theme-secondary text-theme-secondary p-5 text-center uppercase w-full mb-12 lg:w-auto"
		>
		Code Easy
		</h2>
		<p class="text-2xl max-w-7xl italic text-center md:max-w-screen-lg">
			Lorem ipsum dolor sit amet consectetur adipisicing elit. Praesentium, ut
			asperiores totam inventore non quam. Iste accusantium placeat ipsum?
			Dignissimos explicabo cupiditate dicta. Odio nulla debitis laudantium
			iusto, accusantium dolorem?
		</p>
		<Link href="/docs" class="btn btn-primary mt-6" text="View Documentation" />
	</section>

	<section
		id="features"
		class="flex flex-wrap flex-row justify-center gap-12 lg:justify-around"
	>
		<Card
			title="Fast"
			description="Experience blazing speed with Alkaline, optimized for performance and capable of achieving perfect scores on Lighthouse."
			shadowSize="lg"
			name="ri:rocket-2-line"
		/>
		<Card
			title="Flexible"
			description="Leverage Astro's capabilities to build without needing a JavaScript framework. Optionally, add one or multiple frameworks if desired."
			shadowSize="lg"
			name="ri:code-s-slash-line"
		/>
		<Card
			title="Free"
			description="What's mine is yours - Alkaline is open-source and MIT licensed."
			shadowSize="lg"
			name="ri:open-source-line"
		/>
	</section>

	<section class="flex flex-col items-center justify-center mb-64 mt-12">
		<h2
			class="bg-theme-secondary text-theme-secondary p-5 text-center uppercase mb-12 lg:w-auto"
		>
			Created For Developers
		</h2>
		<p class="text-2xl max-w-7xl italic text-center md:max-w-screen-lg">
			Lorem ipsum dolor sit amet consectetur adipisicing elit. Praesentium, ut
			asperiores totam inventore non quam. Iste accusantium placeat ipsum?
			Dignissimos explicabo cupiditate dicta. Odio nulla debitis laudantium
			iusto, accusantium dolorem?
		</p>

		<Link
			href="https://github.com/jaredmakes/alkaline"
			class="btn btn-primary mt-6"
			text="View on GitHub"
		/>
	</section>

	<section class="flex flex-col items-center justify-center mb-32">
		<Image
			src={Bing}
			alt="a quote from Chandler Bing from Friends. Hard work never killed anybody, but why take a chance?"
			class="shadow-md shadow-theme-primary"
			loading="lazy"
			width={1000}
			height={1000}
			format="webp"

		/>

		<h2
			class="bg-theme-secondary text-theme-secondary p-5 text-center uppercase mt-12 lg:w-auto"
		>
			Get Started Today
		</h2>
		<div class="flex flex-wrap gap-3 sm:gap-6 md:gap-8 lg:gap-10 mt-2 justify-start">
			<Link href="#" class="btn btn-primary mt-2" text="Get Started" />
			<Link href="#" class="btn btn-primary mt-2" text="Configuration" />
			<Link href="#" class="btn btn-primary mt-2" text="Components" />
			<Link href="#" class="btn btn-primary mt-2" text="Themes" />
		</div>
	</section>
</Layout>

<style>
	.build-in {
		animation-delay: 0.75s;
	}
</style>

<script></script>
